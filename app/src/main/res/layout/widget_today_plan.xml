<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_today_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_today_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans"
        android:maxLines="1"
        android:text="TidyPilot"
        android:textColor="#14322E"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_today_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Next useful chores"
        android:textColor="#167F75"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_today_energy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#E9FBF4"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="7dp"
            android:text="medium energy"
            android:textColor="#14322E"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_today_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#E9FBF4"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="7dp"
            android:text="15 min"
            android:textColor="#14322E"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_today_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:background="#E9FBF4"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="7dp"
            android:text="Home 70/100"
            android:textColor="#14322E"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="9dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_today_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No chores queued. Add a task or scan a room."
            android:textColor="#14322E"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/widget_task_row_1"
            style="@style/TidyPilotWidgetTaskRow">

            <TextView
                android:id="@+id/widget_task_check_1"
                style="@style/TidyPilotWidgetCheckbox" />

            <LinearLayout style="@style/TidyPilotWidgetTaskTextColumn">
                <TextView
                    android:id="@+id/widget_task_title_1"
                    style="@style/TidyPilotWidgetTaskTitle" />

                <TextView
                    android:id="@+id/widget_task_meta_1"
                    style="@style/TidyPilotWidgetTaskMeta" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_task_row_2"
            style="@style/TidyPilotWidgetTaskRow">

            <TextView
                android:id="@+id/widget_task_check_2"
                style="@style/TidyPilotWidgetCheckbox" />

            <LinearLayout style="@style/TidyPilotWidgetTaskTextColumn">
                <TextView
                    android:id="@+id/widget_task_title_2"
                    style="@style/TidyPilotWidgetTaskTitle" />

                <TextView
                    android:id="@+id/widget_task_meta_2"
                    style="@style/TidyPilotWidgetTaskMeta" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_task_row_3"
            style="@style/TidyPilotWidgetTaskRow">

            <TextView
                android:id="@+id/widget_task_check_3"
                style="@style/TidyPilotWidgetCheckbox" />

            <LinearLayout style="@style/TidyPilotWidgetTaskTextColumn">
                <TextView
                    android:id="@+id/widget_task_title_3"
                    style="@style/TidyPilotWidgetTaskTitle" />

                <TextView
                    android:id="@+id/widget_task_meta_3"
                    style="@style/TidyPilotWidgetTaskMeta" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_task_row_4"
            style="@style/TidyPilotWidgetTaskRow">

            <TextView
                android:id="@+id/widget_task_check_4"
                style="@style/TidyPilotWidgetCheckbox" />

            <LinearLayout style="@style/TidyPilotWidgetTaskTextColumn">
                <TextView
                    android:id="@+id/widget_task_title_4"
                    style="@style/TidyPilotWidgetTaskTitle" />

                <TextView
                    android:id="@+id/widget_task_meta_4"
                    style="@style/TidyPilotWidgetTaskMeta" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_today_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_accent_pill"
        android:gravity="center"
        android:padding="8dp"
        android:text="Open Today's Plan"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
